PORT=5173
HOST=127.0.0.1
APP_URL=http://127.0.0.1:5173

# Optional storage overrides for deployed hosts with persistent disks.
# Leave blank locally unless you know you need them.
DATA_DIR=
UPLOAD_DIR=
DB_PATH=

# Stripe secret key from your Stripe dashboard.
# Use a test key first, for example sk_test_...
STRIPE_SECRET_KEY=

# Stripe webhook signing secret from Stripe CLI or dashboard endpoint.
# Example from Stripe CLI: whsec_...
STRIPE_WEBHOOK_SECRET=

STRIPE_CURRENCY=usd
